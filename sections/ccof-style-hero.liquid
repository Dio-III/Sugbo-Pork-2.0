{% liquid
  assign alignment_class = 'text-' | append: section.settings.text_alignment
  assign has_secondary_cta = section.settings.secondary_button_label != blank
%}

<section class="ccof-hero-wrapper section-wrapper">
  <div class="ccof-hero ccof-hero--{{ section.settings.layout }}">
    <!-- Text Content (Left) -->
    <div class="ccof-hero__content">
      <div class="ccof-hero__content-inner">
        
        <!-- Pre-headline (optional badge) -->
        {% if section.settings.preheadline != blank %}
          <div class="ccof-hero__preheadline">
            {{ section.settings.preheadline }}
          </div>
        {% endif %}

        <!-- Main Headline -->
        <h1 class="ccof-hero__headline">
          {{ section.settings.headline }}
        </h1>

        <!-- Subheadline -->
        {% if section.settings.subheadline != blank %}
          <p class="ccof-hero__subheadline">
            {{ section.settings.subheadline }}
          </p>
        {% endif %}

        <!-- Certification Badges (optional) -->
        {% if section.settings.show_certifications %}
          <div class="ccof-hero__certifications">
            {% if section.settings.certification_badge_1 != blank %}
              <div class="certification-badge">
                {{ section.settings.certification_badge_1 }}
              </div>
            {% endif %}
            {% if section.settings.certification_badge_2 != blank %}
              <div class="certification-badge">
                {{ section.settings.certification_badge_2 }}
              </div>
            {% endif %}
            {% if section.settings.certification_badge_3 != blank %}
              <div class="certification-badge">
                {{ section.settings.certification_badge_3 }}
              </div>
            {% endif %}
          </div>
        {% endif %}

        <!-- Call-to-Action Buttons -->
        <div class="ccof-hero__buttons">
          {% if section.settings.primary_button_label != blank %}
            <a
              href="{{ section.settings.primary_button_link }}"
              class="button button--primary ccof-hero__button"
            >
              {{ section.settings.primary_button_label }}
            </a>
          {% endif %}

          {% if has_secondary_cta %}
            <a
              href="{{ section.settings.secondary_button_link }}"
              class="button button--secondary ccof-hero__button ccof-hero__button--secondary"
            >
              {{ section.settings.secondary_button_label }}
            </a>
          {% endif %}
        </div>

        <!-- Descriptive Text (optional) -->
        {% if section.settings.description != blank %}
          <p class="ccof-hero__description">
            {{ section.settings.description }}
          </p>
        {% endif %}

      </div>
    </div>

    <!-- Image Content (Right) -->
    {% if section.settings.image != blank %}
      <div class="ccof-hero__media">
        {%- capture sizes -%}
          (min-width: 750px) 50vw,
          100vw
        {%- endcapture -%}
        {%- capture widths -%}
          416, 600, 800, 1200, 1600, 2048
        {%- endcapture -%}
        {{
          section.settings.image
          | image_url: width: 2048
          | image_tag:
            width: section.settings.image.width,
            widths: widths,
            height: section.settings.image.height,
            alt: section.settings.image.alt,
            class: 'ccof-hero__image',
            sizes: sizes,
            loading: 'lazy'
        }}
      </div>
    {% else %}
      <div class="ccof-hero__media">
        {{ 'image' | placeholder_svg_tag: 'ccof-hero__image placeholder' }}
      </div>
    {% endif %}

  </div>
</section>

<style>
  .ccof-hero-wrapper {
    margin: 0;
    padding: 0;
  }

  .ccof-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: clamp(1.5rem, 5vw, 4rem);
    min-height: 60vh;
    padding: clamp(2rem, 5vw, 6rem);
    background: var(--color-background);
  }

  .ccof-hero--full-width {
    grid-template-columns: 1fr;
    padding: clamp(2rem, 5vw, 6rem);
  }

  .ccof-hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
  }

  .ccof-hero__content-inner {
    max-width: 600px;
  }

  .ccof-hero__preheadline {
    font-size: clamp(0.75rem, 2vw, 0.875rem);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #a8411a;
    margin-bottom: 1rem;
    line-height: 1.4;
  }

  .ccof-hero__headline {
    font-size: clamp(2rem, 8vw, 4.5rem);
    font-weight: 900;
    line-height: 1.1;
    margin: 0 0 1.5rem 0;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .ccof-hero__subheadline {
    font-size: clamp(1rem, 3vw, 1.375rem);
    line-height: 1.5;
    margin: 0 0 2rem 0;
    color: #666;
    font-weight: 400;
  }

  .ccof-hero__certifications {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin: 2rem 0 2rem 0;
  }

  .certification-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1rem;
    background: #f5f5f5;
    border: 1px solid #ddd;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #333;
    gap: 0.5rem;
  }

  .ccof-hero__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin: 2rem 0;
  }

  .ccof-hero__button {
    padding: 1rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    border: none;
    border-radius: 0;
    cursor: pointer;
    transition: all 0.2s ease-in-out;
    text-decoration: none;
    display: inline-block;
    text-align: center;
    white-space: nowrap;
  }

  .button--primary {
    background: #a8411a;
    color: white;
  }

  .button--primary:hover {
    background: #8a3315;
  }

  .button--secondary {
    background: white;
    color: #333;
    border: 2px solid #333;
  }

  .button--secondary:hover {
    background: #f5f5f5;
  }

  .ccof-hero__description {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #666;
    max-width: 500px;
    margin: 1rem 0 0 0;
  }

  .ccof-hero__media {
    width: 100%;
    height: 100%;
    min-height: 500px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ccof-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Responsive Design */
  @media (max-width: 749px) {
    .ccof-hero {
      grid-template-columns: 1fr;
      gap: 2rem;
      min-height: auto;
      padding: clamp(1.5rem, 4vw, 3rem);
    }

    .ccof-hero__content-inner {
      max-width: 100%;
    }

    .ccof-hero__headline {
      font-size: clamp(1.5rem, 6vw, 2.5rem);
      margin-bottom: 1rem;
    }

    .ccof-hero__subheadline {
      font-size: clamp(0.875rem, 2.5vw, 1.125rem);
      margin-bottom: 1.5rem;
    }

    .ccof-hero__media {
      min-height: 300px;
      order: -1;
    }

    .ccof-hero__buttons {
      flex-direction: column;
      gap: 0.75rem;
    }

    .ccof-hero__button {
      width: 100%;
    }

    .ccof-hero__certifications {
      gap: 0.75rem;
      margin: 1.5rem 0;
    }

    .certification-badge {
      padding: 0.375rem 0.875rem;
      font-size: 0.8125rem;
    }
  }
</style>

{% schema %}
{
  "name": "CCOF Style Hero",
  "tag": "section",
  "class": "ccof-hero-section section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "preheadline",
      "label": "Pre-Headline (Badge)",
      "placeholder": "e.g., CERTIFIED HERITAGE PORK",
      "default": "CERTIFIED HERITAGE PORK"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Headline",
      "placeholder": "Enter main headline",
      "default": "Certified Cebuano Heritage Pork"
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Subheadline",
      "placeholder": "Enter supporting text",
      "default": "Direct from Cebuano farms to your table. Fair trade, transparent sourcing, and heritage breed preservation."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description Text",
      "placeholder": "Optional descriptive text",
      "default": "We partner directly with certified heritage pork farmers across Cebu. Every cut tells the story of sustainable farming and fair trade practices."
    },
    {
      "type": "header",
      "content": "Calls-to-Action"
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary Button Label",
      "default": "Shop the App",
      "placeholder": "e.g., Shop the App"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary Button Label",
      "default": "View Farmer Standards",
      "placeholder": "e.g., View Farmer Standards"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "header",
      "content": "Certifications"
    },
    {
      "type": "checkbox",
      "id": "show_certifications",
      "label": "Show Certification Badges",
      "default": true
    },
    {
      "type": "text",
      "id": "certification_badge_1",
      "label": "Certification Badge 1",
      "default": "Heritage Breed",
      "placeholder": "e.g., Heritage Breed"
    },
    {
      "type": "text",
      "id": "certification_badge_2",
      "label": "Certification Badge 2",
      "default": "Pasture-Raised",
      "placeholder": "e.g., Pasture-Raised"
    },
    {
      "type": "text",
      "id": "certification_badge_3",
      "label": "Certification Badge 3",
      "default": "Fair Trade Certified",
      "placeholder": "e.g., Fair Trade"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image (Right Side)"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout Type",
      "options": [
        {
          "value": "two-column",
          "label": "Two Column (Text Left, Image Right)"
        },
        {
          "value": "full-width",
          "label": "Full Width (Text Only)"
        }
      ],
      "default": "two-column"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "CCOF Style Hero",
      "settings": {
        "preheadline": "CERTIFIED HERITAGE PORK",
        "headline": "Certified Cebuano Heritage Pork",
        "subheadline": "Direct from Cebuano farms to your table. Fair trade, transparent sourcing, and heritage breed preservation.",
        "primary_button_label": "Shop the App",
        "secondary_button_label": "View Farmer Standards",
        "show_certifications": true
      }
    }
  ]
}
{% endschema %}
