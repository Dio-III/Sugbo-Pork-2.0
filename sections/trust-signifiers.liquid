    },
    {
      "type": "checkbox",
      "id": "show_certifications_list",
      "label": "Show Certifications List",
      "default": true
    },
    {
      "type": "text",
      "id": "certifications_heading",
      "label": "Certifications Heading",
      "default": "Our Certifications & Standards"
    },
    {
      "type": "checkbox",
