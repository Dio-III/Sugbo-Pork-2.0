        },
        {
          "type": "select",
          "id": "signifier_type",
          "label": "Signifier Type",
          "default": "Certified Farms",
          "options": [
            { "value": "Certified Farms", "label": "Certified Farms" },
            { "value": "Heritage Breed", "label": "Heritage Breed" },
            { "value": "Fair Trade", "label": "Fair Trade" },
            { "value": "Sustainability", "label": "Sustainability" },
            { "value": "Animal Welfare", "label": "Animal Welfare" }
          ]
        }
      ]
    },
    {
      "type": "certification",
      "name": "Certification Item",
      "settings": [
        {
          "type": "text",
          "id": "certification_name",
          "label": "Certification Name",
          "default": "Heritage Breed Certified"
        }
      ]
    }
  ],
  "presets": [
    {
