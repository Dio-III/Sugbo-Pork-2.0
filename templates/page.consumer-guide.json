{"sections":{"main":{"type":"main"},"consumer_guide_hero":{"type":"custom-liquid","settings":{"custom_liquid":"<style>.cg-hero{padding:4rem 2rem;text-align:center}@media(min-width:990px){.cg-hero{padding:6rem 4rem}}.cg-hero h1{font-size:clamp(2rem,4.5vw,3rem);margin:0 0 1rem}.cg-hero p{font-size:1.1rem;color:#555;max-width:700px;margin:0 auto}</style><section class=\"cg-hero\"><h1>Welcome to Ethical Pork Marketplace</h1><p>Shop fresh, transparently-sourced pork from partnered Cebuano farmers. Choose payment options that work for your household.</p></section>","color_scheme":"scheme-1","section_width":"page-width","padding-block-start":0,"padding-block-end":48}},"consumer_steps":{"type":"custom-liquid","settings":{"custom_liquid":"<style>.cg-steps{padding:3rem 2rem}@media(min-width:990px){.cg-steps{padding:4rem}}.cg-steps h2{text-align:center;font-size:1.8rem;margin:0 0 3rem}.cg-step-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:2rem}.cg-step{background:#f9f9f9;padding:2rem;border-radius:.4rem;text-align:center}.cg-step-number{font-size:2.5rem;font-weight:700;color:#284323;margin-bottom:.5rem}.cg-step h3{font-size:1.3rem;margin:0 0 .8rem}.cg-step p{color:#666;margin:0}</style><section class=\"cg-steps\"><h2>How to Shop</h2><div class=\"cg-step-grid\"><div class=\"cg-step\"><div class=\"cg-step-number\">1</div><h3>Browse & Select</h3><p>Explore fresh pork products. Read source information on each item.</p></div><div class=\"cg-step\"><div class=\"cg-step-number\">2</div><h3>Add to Cart</h3><p>Build your order. Check ingredients and farmer details on each product page.</p></div><div class=\"cg-step\"><div class=\"cg-step-number\">3</div><h3>Choose Payment</h3><p>Cash, COD, or BNPL at checkout. No hidden fees or surprises.</p></div><div class=\"cg-step\"><div class=\"cg-step-number\">4</div><h3>Get Delivered</h3><p>Same-day or next-day delivery across Metro Cebu. Fresh to your table.</p></div></div></section>","color_scheme":"scheme-1","section_width":"page-width","padding-block-start":0,"padding-block-end":48}},"consumer_faq":{"type":"custom-liquid","settings":{"custom_liquid":"<style>.cg-faq{padding:3rem 2rem;background:#f5f5f5}@media(min-width:990px){.cg-faq{padding:4rem}}.cg-faq h2{text-align:center;font-size:1.8rem;margin:0 0 2.5rem}.cg-faq-grid{display:grid;gap:1.5rem;max-width:700px;margin:0 auto}.cg-faq-item{background:#fff;padding:1.5rem;border-radius:.3rem;border-left:3px solid #284323}.cg-faq-item h3{margin:0 0 .5rem;font-size:1.05rem}.cg-faq-item p{margin:0;color:#666;line-height:1.6}</style><section class=\"cg-faq\"><h2>Questions?</h2><div class=\"cg-faq-grid\"><div class=\"cg-faq-item\"><h3>What makes this pork ethical?</h3><p>Our farmers receive above-market pricing for humanely-raised pork. We maintain transparent relationships and supply-chain visibility.</p></div><div class=\"cg-faq-item\"><h3>Is BNPL safe and how does it work?</h3><p>Yes. BNPL splits your purchase into 3 equal payments with no interest if paid on time. Choose it at checkout like any payment method.</p></div><div class=\"cg-faq-item\"><h3>Can I see where my pork came from?</h3><p>Every product includes farmer name, farm location, and sourcing date. Scan the QR code for full farm-to-table traceability.</p></div><div class=\"cg-faq-item\"><h3>What if I need support?</h3><p>Contact us anytime. Our team responds within 2 hours during business hours. Chat, email, or phone available on our contact page.</p></div></div></section>","color_scheme":"scheme-1","section_width":"page-width","padding-block-start":0,"padding-block-end":0}},"cta_section":{"type":"custom-liquid","settings":{"custom_liquid":"<style>.cg-cta{background:linear-gradient(135deg, #284323 0%, #1a2818 100%);color:#fff;padding:3rem 2rem;text-align:center}@media(min-width:990px){.cg-cta{padding:4rem}}.cg-cta h2{font-size:1.5rem;margin:0 0 1rem}.cg-cta a{display:inline-block;padding:.9rem 2rem;background:#fff;color:#284323;text-decoration:none;border-radius:.3rem;font-weight:700;margin-top:1rem}</style><section class=\"cg-cta\"><h2>Ready to shop?</h2><a href=\"/collections/all\">Browse Fresh Pork</a></section>","color_scheme":"scheme-1","section_width":"full-width","padding-block-start":0,"padding-block-end":0}}},"order":["main","consumer_guide_hero","consumer_steps","consumer_faq","cta_section"]}
